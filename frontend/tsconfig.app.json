{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,            // 👈 DIŞ KÜTÜPHANE HATALARINI YOK SAYAR (ÇOK KRİTİK)
    "noUnusedLocals": false,          // 👈 KULLANILMAYAN DEĞİŞKENLERE KIZMAZ
    "noUnusedParameters": false,      // 👈 KULLANILMAYAN PARAMETRELERE KIZMAZ

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true
  },
  "include": ["src"]
}